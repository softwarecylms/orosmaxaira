{
  "name": "informational-template",
  "version": "0.1.0",
  "description": "Studio starter — Next.js 15 + Payload CMS 3 + Puck visual editor. Clone to spin up a new informational/marketing site.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build && node scripts/post-build.mjs",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "lint": "next lint",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/payload/seed/index.ts",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "deploy:start": "cross-env PORT=3001 node .next/standalone/server.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@measured/puck": "^0.20.2",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/payload-cloud": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "framer-motion": "^11.15.0",
    "graphql": "^16.10.0",
    "lucide-react": "^0.469.0",
    "next": "15.4.11",
    "nodemailer": "^6.9.16",
    "payload": "3.84.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "sharp": "0.33.5",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.4.11",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@11.1.3"
}
