# Public site URL (canonical URLs, sitemap, OG tags, llms.txt). No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Payload secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-me-with-a-long-random-string

# PostgreSQL connection string.
#   Local (Homebrew):  brew install postgresql@15 && brew services start postgresql@15 && createdb app
#   Cloud (Neon/Vercel/Supabase): use the POOLED connection string for serverless.
# NOTE: payload.config.ts reads DATABASE_URI. If your host provides DATABASE_URL, either
# rename it here or set DATABASE_URI=$DATABASE_URL.
DATABASE_URI=postgres://postgres:postgres@localhost:5432/app

# SMTP (contact form via /api/contact)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@example.com
SMTP_PASSWORD=replace-me
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=no-reply@example.com

# On-demand ISR revalidation secret (Payload -> Next)
REVALIDATION_SECRET=replace-me-with-a-long-random-string
